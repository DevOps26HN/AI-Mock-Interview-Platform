# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=interview_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# PostgreSQL Image Configuration (used by compose)
POSTGRES_DB=interview_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# GenAI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GENAI_BACKEND=local # 'gemini' or 'local'
LOCAL_MODEL_URL=http://localhost:11434/api/generate # Use http://host.docker.internal:11434/api/generate for host Ollama
GENAI_SERVICE_URL=http://genai:8000

# Client Configuration
VITE_API_URL=http://localhost:8080

# Grafana Login
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
