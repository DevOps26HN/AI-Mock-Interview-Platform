# ==============================================================================
# Ansible Inventory Example (inventory.ini.example)
# ==============================================================================
# Instructions:
# 1. Copy this file to 'inventory.ini':
#    cp inventory.ini.example inventory.ini
# 2. Replace 'YOUR_VM_PUBLIC_IP' with the actual public IP address output by Terraform.
# 3. Adjust the private key file path if your key is not stored at '~/.ssh/id_rsa'.
# ==============================================================================

[webservers]
interview_vm ansible_host=YOUR_VM_PUBLIC_IP ansible_user=azureuser ansible_ssh_private_key_file=~/.ssh/id_rsa ansible_ssh_common_args='-o StrictHostKeyChecking=no'
