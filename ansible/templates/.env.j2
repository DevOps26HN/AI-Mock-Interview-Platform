# ==============================================================================
# Dynamic Environment Configurations for Cloud Deployment (.env)
# ==============================================================================
# Generated dynamically by Ansible. Manual modifications may be overwritten.
# ==============================================================================

# Database Connection (Inter-container communication)
DB_HOST=db
DB_PORT=5432
DB_NAME={{ db_name }}
DB_USERNAME={{ db_user }}
DB_PASSWORD={{ db_password }}

# PostgreSQL Container Initialization
POSTGRES_DB={{ db_name }}
POSTGRES_USER={{ db_user }}
POSTGRES_PASSWORD={{ db_password }}

# Client Build-time Endpoint Configuration
# Note: This is read during client container compilation to point browser requests
# to the backend server running on the VM's public IP address.
VITE_API_URL=http://{{ ansible_host }}:8080
